<div class="overlay" id="modal-custo">
  <div class="modal">
    <div class="modal-title">🏢 Custo Fixo</div>
    <div class="form-group"><label class="form-label">Descrição</label>
      <input class="form-input" id="cf-desc" placeholder="Ex: Aluguel, Internet..."/></div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Valor (R$)</label>
        <input class="form-input" id="cf-valor" type="number" step="0.01" placeholder="0,00"/></div>
      <div class="form-group"><label class="form-label">Dia de Vencimento</label>
        <input class="form-input" id="cf-dia" type="number" min="1" max="31" placeholder="10"/></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Categoria</label>
        <select class="form-select" id="cf-cat">
          <option>Imóvel</option><option>Utilidades</option><option>Comunicação</option>
          <option>Software</option><option>Serviços</option><option>Seguros</option>
          <option>Marketing</option><option>Manutenção</option><option>Outros</option>
        </select></div>
      <div class="form-group"><label class="form-label">Forma de Pagamento</label>
        <select class="form-select" id="cf-forma">
          <option>Boleto</option><option>Débito Auto</option><option>Cartão Crédito</option>
          <option>PIX</option><option>Transferência</option>
        </select></div>
    </div>
    <div class="modal-actions">
      <button class="btn" onclick="closeModal('modal-custo')">Cancelar</button>
      <button class="btn btn-primary" onclick="addCusto()">Adicionar</button>
    </div>
  </div>
</div>

<div class="overlay" id="modal-func">
  <div class="modal">
    <div class="modal-title">👤 Funcionário</div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Nome</label>
        <input class="form-input" id="func-nome" placeholder="Nome completo"/></div>
      <div class="form-group"><label class="form-label">Cargo</label>
        <input class="form-input" id="func-cargo" placeholder="Ex: Vendedor"/></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Salário Base (R$)</label>
        <input class="form-input" id="func-sal" type="number" step="0.01" placeholder="0,00"/></div>
      <div class="form-group"><label class="form-label">Vale Transporte (R$)</label>
        <input class="form-input" id="func-vt" type="number" step="0.01" placeholder="0,00"/></div>
    </div>
    <div class="form-group"><label class="form-label">Vale Refeição (R$)</label>
      <input class="form-input" id="func-vr" type="number" step="0.01" placeholder="0,00"/></div>
    <div class="modal-actions">
      <button class="btn" onclick="closeModal('modal-func')">Cancelar</button>
      <button class="btn btn-primary" onclick="addFuncionario()">Adicionar</button>
    </div>
  </div>
</div>

<div class="toast-wrap" id="toasts"></div>

<script>
// ═══════════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════════
const MESES = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho',
               'Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
const FORMAS_REC = [
  {key:'cartao_credito', label:'Cartão Crédito', icon:'💳', color:'#3b82f6'},
  {key:'cartao_debito',  label:'Cartão Débito',  icon:'💳', color:'#6366f1'},
  {key:'pix',           label:'PIX',            icon:'📱', color:'#2dd4bf'},
  {key:'dinheiro',      label:'Dinheiro',        icon:'💵', color:'#22c55e'},
  {key:'crediario',     label:'Crediário',       icon:'📋', color:'#a78bfa'},
];

let currentMonth = new Date().getMonth(); // 0-indexed

function storageKey(type, month) {
  return `finctrl_2026_${type}_m${month}`;
}
function globalKey(type) {
  return `finctrl_2026_global_${type}`;
}

function load(key) {
  try { return JSON.parse(localStorage.getItem(key)) || null; } catch { return null; }
}
function save(key, data) {
  localStorage.setItem(key, JSON.stringify(data));
}

function getRecebimentos(m) {
  return load(storageKey('rec', m)) || {};
}
function getBoletos(m) {
  return load(storageKey('bol', m)) || [];
}
function getCustos() {
  return load(globalKey('custos')) || [];
}
function getFuncionarios() {
  return load(globalKey('funcs')) || [];
}
function getCustosStatus(m) {
  return load(storageKey('cf_status', m)) || {};
}
function getFuncStatus(m) {
  return load(storageKey('func_status', m)) || {};
}

// ═══════════════════════════════════════════════════════════
// UTILS
// ═══════════════════════════════════════════════════════════
function brl(v) {
  return new Intl.NumberFormat('pt-BR',{style:'currency',currency:'BRL'}).format(v||0);
}
function dateStr(d) {
  if(!d) return '—';
  const p = d.split('-');
  return `${p[2]}/${p[1]}/${p[0]}`;
}
function uid() { return Math.random().toString(36).slice(2,9); }

function toast(msg, type='success') {
  const wrap = document.getElementById('toasts');
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.innerHTML = (type==='success'?'✅':type==='error'?'❌':'ℹ️') + ' ' + msg;
  wrap.appendChild(el);
  setTimeout(()=>el.remove(), 3000);
}

function statusBadge(status, onclick) {
  const map = {pendente:'pendente',pago:'pago',vencido:'vencido',cancelado:'cancelado'};
  const cls = map[status?.toLowerCase()]||'pendente';
  const dot = cls==='pago'?'●':cls==='vencido'?'●':cls==='cancelado'?'—':'●';
  return `<span class="badge ${cls}" onclick="${onclick}">${dot} ${status||'PENDENTE'}</span>`;
}

function nextStatus(s) {
  const cycle = ['PENDENTE','PAGO','VENCIDO','CANCELADO'];
  const i = cycle.indexOf((s||'PENDENTE').toUpperCase());
  return cycle[(i+1)%cycle.length];
}

// ═══════════════════════════════════════════════════════════
// NAVIGATION
// ═══════════════════════════════════════════════════════════
const pageNames = {
  dashboard:'Resumo Geral', recebimentos:'Recebimentos',
  boletos:'Boletos / Contas', custos:'Custos Fixos', funcionarios:'Funcionários'
};

function showPage(id) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  document.querySelector(`[onclick="showPage('${id}')"]`).classList.add('active');
  document.getElementById('topbar-title').textContent = pageNames[id];
  closeSidebar();
  renderPage(id);
}

function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
}
function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
}

// ═══════════════════════════════════════════════════════════
// MONTH TABS
// ═══════════════════════════════════════════════════════════
function renderMonthTabs() {
  const wrap = document.getElementById('month-tabs');
  wrap.innerHTML = MESES.map((m,i)=>
    `<button class="month-tab${i===currentMonth?' active':''}" onclick="setMonth(${i})">${m.slice(0,3)}</button>`
  ).join('');
  document.getElementById('topbar-month-label').textContent = MESES[currentMonth]+' 2026';
}

function setMonth(i) {
  currentMonth = i;
  renderMonthTabs();
  const active = document.querySelector('.page.active');
  if(active) renderPage(active.id.replace('page-',''));
}

function cycleMonth() {
  setMonth((currentMonth+1)%12);
}

// ═══════════════════════════════════════════════════════════
// MODALS
// ═══════════════════════════════════════════════════════════
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.overlay').forEach(o=>{
  o.addEventListener('click', e=>{ if(e.target===o) o.classList.remove('open'); });
});

// ═══════════════════════════════════════════════════════════
// RENDER PAGE ROUTER
// ═══════════════════════════════════════════════════════════
function renderPage(id) {
  if(id==='dashboard') renderDashboard();
  if(id==='recebimentos') renderRecebimentos();
  if(id==='boletos') renderBoletos();
  if(id==='custos') renderCustos();
  if(id==='funcionarios') renderFuncionarios();
  updateBadge();
}

// ═══════════════════════════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════════════════════════
function renderDashboard() {
  const m = currentMonth;
  const rec = getRecebimentos(m);
  const bols = getBoletos(m);
  const custos = getCustos();
  const funcs = getFuncionarios();
  const cfStatus = getCustosStatus(m);
  const fStatus = getFuncStatus(m);

  const totalRec = FORMAS_REC.reduce((s,f)=>s+(parseFloat(rec[f.key])||0), 0);
  const bolPagos = bols.filter(b=>b.status==='PAGO').reduce((s,b)=>s+(b.valor||0),0);
  const bolPend  = bols.filter(b=>b.status==='PENDENTE').reduce((s,b)=>s+(b.valor||0),0);
  const bolVenc  = bols.filter(b=>b.status==='VENCIDO').reduce((s,b)=>s+(b.valor||0),0);
  const totalCF  = custos.reduce((s,c)=>s+(c.valor||0),0);
  const totalFolha = funcs.reduce((s,f)=>s+(f.sal||0)+(f.sal||0)*.11+(f.sal||0)*.08+(f.vt||0)+(f.vr||0),0);
  const saldo = totalRec - bolPagos - totalCF - totalFolha;

  // Cards
  document.getElementById('dash-cards').innerHTML = [
    {label:'💰 Total Recebido', val:totalRec, cls:'positive'},
    {label:'✅ Boletos Pagos', val:bolPagos, cls:''},
    {label:'⏳ Boletos Pendentes', val:bolPend, cls:'warning'},
    {label:'❌ Boletos Vencidos', val:bolVenc, cls:'negative'},
    {label:'🏢 Custos Fixos', val:totalCF, cls:''},
    {label:'👥 Folha de Pagamento', val:totalFolha, cls:''},
    {label:'📊 Saldo do Mês', val:saldo, cls:saldo>=0?'positive':'negative', highlight:true},
  ].map(c=>`
    <div class="card${c.highlight?' highlight':''}">
      <div class="card-label">${c.label}</div>
      <div class="card-value ${c.cls}">${brl(c.val)}</div>
    </div>`).join('');

  // Recebimentos breakdown
  const total = totalRec || 1;
  document.getElementById('dash-rec-breakdown').innerHTML = `
    <div class="table-head"><div class="table-head-title">💰 Recebimentos por Categoria</div></div>
    <table><tbody>${FORMAS_REC.map(f=>{
      const v = parseFloat(rec[f.key])||0;
      const pct = totalRec>0 ? (v/totalRec*100).toFixed(1) : 0;
      return `<tr><td style="width:150px">
        <span style="display:inline-flex;align-items:center;gap:8px">
          <span style="width:10px;height:10px;border-radius:50%;background:${f.color};display:inline-block"></span>
          ${f.label}
        </span></td>
        <td style="width:60%">
          <div class="progress-bar"><div class="progress-fill" style="width:${pct}%;background:${f.color}"></div></div>
        </td>
        <td class="td-right td-mono">${brl(v)}</td>
        <td class="td-right" style="color:var(--text3);font-size:.78rem">${pct}%</td>
      </tr>`;}).join('')}</tbody></table>`;

  // Últimos boletos
  const tbody = document.getElementById('dash-boletos-table');
  if(!bols.length) {
    tbody.innerHTML = '<tr><td colspan="4"><div class="empty"><div class="empty-icon">📭</div><div class="empty-text">Nenhum boleto lançado neste mês</div></div></td></tr>';
  } else {
    tbody.innerHTML = bols.slice(-5).reverse().map((b,i)=>`
      <tr>
        <td>${b.desc}</td>
        <td style="color:var(--text3);font-size:.82rem">${dateStr(b.venc)}</td>
        <td class="td-right td-mono">${brl(b.valor)}</td>
        <td>${statusBadge(b.status, `toggleBolStatus(${bols.indexOf(b)})`)}</td>
      </tr>`).join('');
  }
}

// ═══════════════════════════════════════════════════════════
// RECEBIMENTOS
// ═══════════════════════════════════════════════════════════
function renderRecebimentos() {
  const m = currentMonth;
  const rec = getRecebimentos(m);
  document.getElementById('rec-inputs').innerHTML = FORMAS_REC.map(f=>`
    <div class="rec-card">
      <div class="rec-card-top">
        <div class="rec-icon" style="background:${f.color}22;color:${f.color}">${f.icon}</div>
        <div class="rec-name">${f.label}</div>
      </div>
      <div class="rec-input-wrap">
        <span>R$</span>
        <input class="rec-input" id="rec-${f.key}"
          type="number" step="0.01" min="0"
          value="${rec[f.key]||''}"
          placeholder="0,00"
          oninput="updateRecTotal()"/>
      </div>
    </div>`).join('');
  updateRecTotal();
}

function updateRecTotal() {
  const total = FORMAS_REC.reduce((s,f)=>{
    const v = parseFloat(document.getElementById('rec-'+f.key)?.value)||0;
    return s+v;
  },0);
  document.getElementById('rec-total-display').textContent = brl(total);
}

function saveRecebimentos() {
  const m = currentMonth;
  const data = {};
  FORMAS_REC.forEach(f=>{
    data[f.key] = parseFloat(document.getElementById('rec-'+f.key)?.value)||0;
  });
  save(storageKey('rec', m), data);
  toast('Recebimentos salvos!');
  updateBadge();
}

// ═══════════════════════════════════════════════════════════
// BOLETOS
// ═══════════════════════════════════════════════════════════
function addBoleto() {
  const desc  = document.getElementById('bol-desc').value.trim();
  const venc  = document.getElementById('bol-venc').value;
  const valor = parseFloat(document.getElementById('bol-valor').value)||0;
  const cat   = document.getElementById('bol-cat').value;
  const forma = document.getElementById('bol-forma').value;
  if(!desc||!valor) { toast('Preencha descrição e valor','error'); return; }
  const m = currentMonth;
  const bols = getBoletos(m);
  bols.push({id:uid(),desc,venc,valor,cat,forma,status:'PENDENTE'});
  save(storageKey('bol',m), bols);
  closeModal('modal-boleto');
  document.getElementById('bol-desc').value='';
  document.getElementById('bol-venc').value='';
  document.getElementById('bol-valor').value='';
  toast('Boleto adicionado!');
  renderBoletos();
  updateBadge();
}

function toggleBolStatus(idx) {
  const m = currentMonth;
  const bols = getBoletos(m);
  if(!bols[idx]) return;
  bols[idx].status = nextStatus(bols[idx].status);
  save(storageKey('bol',m), bols);
  renderBoletos();
  renderDashboard();
  updateBadge();
  if(bols[idx].status==='PAGO') toast(`✅ "${bols[idx].desc}" marcado como PAGO`,'success');
}

function deleteBoleto(idx) {
  const m = currentMonth;
  const bols = getBoletos(m);
  if(!confirm(`Remover "${bols[idx]?.desc}"?`)) return;
  bols.splice(idx,1);
  save(storageKey('bol',m), bols);
  toast('Removido','info');
  renderBoletos();
  updateBadge();
}

function renderBoletos() {
  const m = currentMonth;
  const bols = getBoletos(m);
  const pago  = bols.filter(b=>b.status==='PAGO').reduce((s,b)=>s+b.valor,0);
  const pend  = bols.filter(b=>b.status==='PENDENTE').reduce((s,b)=>s+b.valor,0);
  const venc  = bols.filter(b=>b.status==='VENCIDO').reduce((s,b)=>s+b.valor,0);
  const total = bols.reduce((s,b)=>s+b.valor,0);

  document.getElementById('bol-summary-cards').innerHTML = [
    {label:'Total do Mês', val:total, cls:''},
    {label:'✅ Pagos', val:pago, cls:'positive'},
    {label:'⏳ Pendentes', val:pend, cls:'warning'},
    {label:'❌ Vencidos', val:venc, cls:'negative'},
  ].map(c=>`<div class="card"><div class="card-label">${c.label}</div>
    <div class="card-value ${c.cls}">${brl(c.val)}</div></div>`).join('');

  const tbody = document.getElementById('bol-table');
  if(!bols.length) {
    tbody.innerHTML='<tr><td colspan="7"><div class="empty"><div class="empty-icon">📭</div><div class="empty-text">Nenhum boleto — clique em + Adicionar</div></div></td></tr>';
    return;
  }
  tbody.innerHTML = bols.map((b,i)=>`
    <tr>
      <td>${b.desc}</td>
      <td style="color:var(--text3);font-size:.82rem">${b.cat}</td>
      <td style="color:var(--text3);font-size:.82rem">${dateStr(b.venc)}</td>
      <td class="td-right td-mono">${brl(b.valor)}</td>
      <td style="font-size:.8rem;color:var(--text2)">${b.forma}</td>
      <td>${statusBadge(b.status, `toggleBolStatus(${i})`)}</td>
      <td><button class="btn btn-sm btn-red" onclick="deleteBoleto(${i})">🗑</button></td>
    </tr>`).join('');
}

// ═══════════════════════════════════════════════════════════
// CUSTOS FIXOS
// ═══════════════════════════════════════════════════════════
function addCusto() {
  const desc  = document.getElementById('cf-desc').value.trim();
  const valor = parseFloat(document.getElementById('cf-valor').value)||0;
  const dia   = document.getElementById('cf-dia').value||'—';
  const cat   = document.getElementById('cf-cat').value;
  const forma = document.getElementById('cf-forma').value;
  if(!desc||!valor) { toast('Preencha descrição e valor','error'); return; }
  const custos = getCustos();
  custos.push({id:uid(),desc,valor,dia,cat,forma});
  save(globalKey('custos'), custos);
  closeModal('modal-custo');
  document.getElementById('cf-desc').value='';
  document.getElementById('cf-valor').value='';
  document.getElementById('cf-dia').value='';
  toast('Custo fixo adicionado!');
  renderCustos();
}

function toggleCfStatus(idx) {
  const m = currentMonth;
  const st = getCustosStatus(m);
  const custos = getCustos();
  const id = custos[idx]?.id;
  if(!id) return;
  st[id] = nextStatus(st[id]||'PENDENTE');
  save(storageKey('cf_status',m), st);
  renderCustos();
  if(st[id]==='PAGO') toast(`✅ "${custos[idx].desc}" marcado como PAGO`,'success');
}

function deleteCusto(idx) {
  const custos = getCustos();
  if(!confirm(`Remover "${custos[idx]?.desc}"?`)) return;
  custos.splice(idx,1);
  save(globalKey('custos'), custos);
  toast('Removido','info');
  renderCustos();
}

function renderCustos() {
  const m = currentMonth;
  const custos = getCustos();
  const st = getCustosStatus(m);
  const total = custos.reduce((s,c)=>s+c.valor,0);
  const pagos = custos.filter(c=>st[c.id]==='PAGO').reduce((s,c)=>s+c.valor,0);

  document.getElementById('cf-summary-cards').innerHTML = [
    {label:'Total Mensal', val:total, cls:''},
    {label:'✅ Pagos este mês', val:pagos, cls:'positive'},
    {label:'⏳ Em aberto', val:total-pagos, cls:'warning'},
  ].map(c=>`<div class="card"><div class="card-label">${c.label}</div>
    <div class="card-value ${c.cls}">${brl(c.val)}</div></div>`).join('');

  const tbody = document.getElementById('cf-table');
  if(!custos.length) {
    tbody.innerHTML='<tr><td colspan="7"><div class="empty"><div class="empty-icon">🏢</div><div class="empty-text">Nenhum custo fixo cadastrado</div></div></td></tr>';
    return;
  }
  tbody.innerHTML = custos.map((c,i)=>`
    <tr>
      <td>${c.desc}</td>
      <td style="color:var(--text3);font-size:.82rem">${c.cat}</td>
      <td style="color:var(--text3);font-size:.82rem;text-align:center">Dia ${c.dia}</td>
      <td class="td-right td-mono">${brl(c.valor)}</td>
      <td style="font-size:.8rem;color:var(--text2)">${c.forma}</td>
      <td>${statusBadge(st[c.id]||'PENDENTE', `toggleCfStatus(${i})`)}</td>
      <td><button class="btn btn-sm btn-red" onclick="deleteCusto(${i})">🗑</button></td>
    </tr>`).join('');
}

// ═══════════════════════════════════════════════════════════
// FUNCIONÁRIOS
// ═══════════════════════════════════════════════════════════
function addFuncionario() {
  const nome = document.getElementById('func-nome').value.trim();
  const cargo= document.getElementById('func-cargo').value.trim();
  const sal  = parseFloat(document.getElementById('func-sal').value)||0;
  const vt   = parseFloat(document.getElementById('func-vt').value)||0;
  const vr   = parseFloat(document.getElementById('func-vr').value)||0;
  if(!nome||!sal) { toast('Preencha nome e salário','error'); return; }
  const funcs = getFuncionarios();
  funcs.push({id:uid(),nome,cargo,sal,vt,vr});
  save(globalKey('funcs'), funcs);
  closeModal('modal-func');
  ['func-nome','func-cargo','func-sal','func-vt','func-vr'].forEach(id=>document.getElementById(id).value='');
  toast('Funcionário adicionado!');
  renderFuncionarios();
}

function toggleFuncStatus(idx) {
  const m = currentMonth;
  const st = getFuncStatus(m);
  const funcs = getFuncionarios();
  const id = funcs[idx]?.id;
  if(!id) return;
  st[id] = nextStatus(st[id]||'PENDENTE');
  save(storageKey('func_status',m), st);
  renderFuncionarios();
  if(st[id]==='PAGO') toast(`✅ Salário de "${funcs[idx].nome}" marcado como PAGO`,'success');
}

function deleteFuncionario(idx) {
  const funcs = getFuncionarios();
  if(!confirm(`Remover "${funcs[idx]?.nome}"?`)) return;
  funcs.splice(idx,1);
  save(globalKey('funcs'), funcs);
  toast('Removido','info');
  renderFuncionarios();
}

function renderFuncionarios() {
  const m = currentMonth;
  const funcs = getFuncionarios();
  const st = getFuncStatus(m);

  const totalSal   = funcs.reduce((s,f)=>s+f.sal,0);
  const totalInss  = funcs.reduce((s,f)=>s+f.sal*.11,0);
  const totalFgts  = funcs.reduce((s,f)=>s+f.sal*.08,0);
  const totalCusto = funcs.reduce((s,f)=>s+f.sal+f.sal*.11+f.sal*.08+f.vt+f.vr,0);

  document.getElementById('func-summary-cards').innerHTML = [
    {label:'👥 Funcionários', val:funcs.length+' pessoas', mono:false},
    {label:'💼 Total Salários', val:brl(totalSal), mono:true},
    {label:'📋 INSS (11%)', val:brl(totalInss), mono:true},
    {label:'🏦 FGTS (8%)', val:brl(totalFgts), mono:true},
    {label:'💰 Custo Total Folha', val:brl(totalCusto), mono:true, highlight:true},
  ].map(c=>`<div class="card${c.highlight?' highlight':''}">
    <div class="card-label">${c.label}</div>
    <div class="card-value">${c.val}</div>
  </div>`).join('');

  const wrap = document.getElementById('func-cards');
  if(!funcs.length) {
    wrap.innerHTML='<div class="empty" style="grid-column:1/-1"><div class="empty-icon">👥</div><div class="empty-text">Nenhum funcionário cadastrado</div></div>';
    return;
  }

  wrap.innerHTML = funcs.map((f,i)=>{
    const inss = f.sal*.11, fgts = f.sal*.08;
    const custo = f.sal+inss+fgts+(f.vt||0)+(f.vr||0);
    const initials = f.nome.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
    const status = st[f.id]||'PENDENTE';
    return `
    <div class="func-card">
      <div class="func-card-top">
        <div class="func-avatar">${initials}</div>
        <div>
          <div class="func-name">${f.nome}</div>
          <div class="func-cargo">${f.cargo||'—'}</div>
        </div>
        <div style="margin-left:auto">${statusBadge(status,`toggleFuncStatus(${i})`)}</div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;font-size:.8rem;color:var(--text2);margin-bottom:10px">
        <div>Salário: <span class="func-salario">${brl(f.sal)}</span></div>
        <div>INSS: <span style="font-family:var(--mono)">${brl(inss)}</span></div>
        <div>FGTS: <span style="font-family:var(--mono)">${brl(fgts)}</span></div>
        <div>VT: <span style="font-family:var(--mono)">${brl(f.vt)}</span></div>
        <div>VR: <span style="font-family:var(--mono)">${brl(f.vr)}</span></div>
        <div><strong>Custo Total:</strong><br><span style="font-family:var(--mono);color:var(--teal)">${brl(custo)}</span></div>
      </div>
      <div class="func-actions">
        <button class="btn btn-sm btn-red" onclick="deleteFuncionario(${i})">🗑 Remover</button>
      </div>
    </div>`;
  }).join('');
}

// ═══════════════════════════════════════════════════════════
// BADGE
// ═══════════════════════════════════════════════════════════
function updateBadge() {
  const m = currentMonth;
  const bols = getBoletos(m);
  const pend = bols.filter(b=>b.status==='PENDENTE'||b.status==='VENCIDO').length;
  const badge = document.getElementById('badge-pendentes');
  badge.textContent = pend;
  badge.style.display = pend>0?'':'none';
}

// ═══════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════
function init() {
  renderMonthTabs();
  renderDashboard();
  updateBadge();
}

init();
</script>

</body>
