<script>
firebase.initializeApp({
  apiKey:"AIzaSyB6ZJi8fWvkheRqHm3EmgdkokM8irNfqQ4",
  authDomain:"bigfarma-2026.firebaseapp.com",
  projectId:"bigfarma-2026",
  storageBucket:"bigfarma-2026.firebasestorage.app",
  messagingSenderId:"925149243217",
  appId:"1:925149243217:web:38941da6346a8855945570"
});
const db = firebase.firestore();

const USERS=[
  {id:'admin',name:'Administrador',role:'admin', color:'#0E8C5A',av:'AD'},
  {id:'u1',   name:'Ebenezer',      role:'viewer',color:'#3D5564',av:'EB'},
  {id:'u2',   name:'Tami',          role:'viewer',color:'#B9740A',av:'TM'},
  {id:'u3',   name:'Funcionário 3',role:'viewer',color:'#7C5C9E',av:'F3'},
];
const MESES=['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
const FORMAS=[
  {k:'cc', l:'Cartão Crédito',c:'#0E8C5A'},
  {k:'cd', l:'Cartão Débito', c:'#3D5564'},
  {k:'pix',l:'PIX',           c:'#1AA179'},
  {k:'din',l:'Dinheiro',      c:'#B9740A'},
  {k:'cre',l:'Crediário',     c:'#7C5C9E'},
];

let curUser=null,selUid='admin',curM=new Date().getMonth();
const cache={};

async function dbSet(key,val){cache[key]=val;try{await db.collection('data').doc(key).set({v:JSON.stringify(val)});}catch(e){localStorage.setItem(key,JSON.stringify(val));}}
async function dbGet(key){if(cache[key]!==undefined)return cache[key];try{const s=await db.collection('data').doc(key).get();const v=s.exists?JSON.parse(s.data().v):null;cache[key]=v;return v;}catch(e){try{return JSON.parse(localStorage.getItem(key));}catch{return null;}}}
const mk=(t,m)=>m!==undefined?`bf26_${t}_m${m}`:`bf26_${t}`;
const getRec =m=>dbGet(mk('rec',m)).then(v=>v||{});
const getBols=m=>dbGet(mk('bol',m)).then(v=>v||[]);
const getFix =()=>dbGet(mk('fix')).then(v=>v||[]);
const getFns =()=>dbGet(mk('fns')).then(v=>v||[]);
const getCfSt=m=>dbGet(mk('cfst',m)).then(v=>v||{});
const getFnSt=m=>dbGet(mk('fnst',m)).then(v=>v||{});
async function preload(m){await Promise.all([dbGet(mk('rec',m)),dbGet(mk('bol',m)),dbGet(mk('fix')),dbGet(mk('fns')),dbGet(mk('cfst',m)),dbGet(mk('fnst',m))]);}

const brl=v=>new Intl.NumberFormat('pt-BR',{style:'currency',currency:'BRL'}).format(v||0);
const fd=d=>{if(!d)return'—';const p=d.split('-');return`${p[2]}/${p[1]}`;};
const uid=()=>Math.random().toString(36).slice(2,9);

function toast(msg,type='ok'){const w=document.getElementById('tw');const el=document.createElement('div');el.className=`toast ${type}`;el.innerHTML=`<span class="td"></span>${msg}`;w.appendChild(el);setTimeout(()=>el.remove(),2800);}
function nextSt(s){const c=['PENDENTE','PAGO','VENCIDO','CANCELADO'];return c[(c.indexOf(s||'PENDENTE')+1)%c.length];}
function badge(s,oc){const cls=(s||'PENDENTE').toLowerCase();return`<span class="badge ${cls}" onclick="${oc}">${s||'PENDENTE'}</span>`;}

async function sha(str){const b=await crypto.subtle.digest('SHA-256',new TextEncoder().encode(str));return Array.from(new Uint8Array(b)).map(x=>x.toString(16).padStart(2,'0')).join('');}
async function checkPw(id,pw){const st=localStorage.getItem('pw_'+id);const h=await sha(pw);if(st)return st===h;const def={admin:'01080508',u1:'639639',u2:'18581858',u3:'1234'};return h===await sha(def[id]||'');}
async function setPw(id,pw){localStorage.setItem('pw_'+id,await sha(pw));}

function renderUsers(){document.getElementById('user-btns').innerHTML=USERS.map(u=>`<button class="u-item${u.id===selUid?' sel':''}" onclick="selUser('${u.id}')"><div class="u-av" style="background:${u.color}1f;color:${u.color}">${u.av}</div><div class="u-info"><div class="name">${u.name}</div><div class="role">${u.role==='admin'?'Administrador':'Visualizador'}</div></div></button>`).join('');}
function selUser(id){selUid=id;renderUsers();document.getElementById('pw-inp').focus();document.getElementById('login-err').textContent='';}
function togglePw(){const i=document.getElementById('pw-inp');i.type=i.type==='password'?'text':'password';}
async function doLogin(){const pw=document.getElementById('pw-inp').value;const err=document.getElementById('login-err');if(!pw){err.textContent='Digite a senha';return;}const ok=await checkPw(selUid,pw);if(!ok){err.textContent='Senha incorreta';document.getElementById('pw-inp').value='';return;}curUser=USERS.find(u=>u.id===selUid);document.getElementById('login').classList.add('off');document.getElementById('app').classList.add('on');document.getElementById('pw-inp').value='';err.textContent='';applyRole();renderMG();await preload(curM);await renderPage('resumo');updateBadge();}
function applyRole(){document.getElementById('ro-bar').style.display=curUser.role==='admin'?'none':'flex';}
function isAdmin(){return curUser?.role==='admin';}
function guard(){if(!isAdmin()){toast('Apenas o admin pode editar','err');return false;}return true;}

const PT={resumo:'Resumo',rec:'Entradas',bol:'Boletos',fix:'Custos Fixos',eq:'Equipe'};
const FABP=['bol','fix','eq'];
async function go(id){document.querySelectorAll('.page').forEach(p=>p.classList.remove('on'));document.querySelectorAll('.nb').forEach(b=>b.classList.remove('on'));document.getElementById('page-'+id).classList.add('on');document.getElementById('nb-'+id).classList.add('on');document.getElementById('ttitle').textContent=PT[id];document.getElementById('fab').className=FABP.includes(id)&&isAdmin()?'fab':'fab off';document.getElementById('scroll').scrollTo(0,0);await renderPage(id);}
async function renderPage(id){if(id==='resumo')await rResumo();if(id==='rec')await rRec();if(id==='bol')await rBol();if(id==='fix')await rFix();if(id==='eq')await rEq();updateBadge();}
function curPage(){return document.querySelector('.nb.on')?.id?.replace('nb-','')||'resumo';}
function openAdd(){const p=curPage();if(p==='bol')openSheet('s-bol');if(p==='fix')openSheet('s-fix');if(p==='eq')openSheet('s-fn');}
function openSheet(id){if(id==='s-cfg')renderCfg();document.getElementById(id).classList.add('on');}
function closeSheet(id){document.getElementById(id).classList.remove('on');}
async function updateBadge(){const n=(await getBols(curM)).filter(b=>b.s==='PENDENTE'||b.s==='VENCIDO').length;const el=document.getElementById('bpend');el.textContent=n;el.className=n?'nbadge':'nbadge off';}

function renderMG(){document.getElementById('mgrid').innerHTML=MESES.map((m,i)=>`<div class="mbtn${i===curM?' on':''}" onclick="setM(${i})">${m.slice(0,3)}</div>`).join('');document.getElementById('mlabel').textContent=MESES[curM];const rl=document.getElementById('rec-mes-label');if(rl)rl.textContent=MESES[curM];}
function openMov(){document.getElementById('mov').classList.add('on');}
function closeMov(){document.getElementById('mov').classList.remove('on');}
async function setM(i){curM=i;closeMov();renderMG();await preload(i);await renderPage(curPage());}

async function rResumo(){
  const [rec,bols,fix,fns]=await Promise.all([getRec(curM),getBols(curM),getFix(),getFns()]);
  const tRec=FORMAS.reduce((s,f)=>s+(parseFloat(rec[f.k])||0),0);
  const bPago=bols.filter(b=>b.s==='PAGO').reduce((s,b)=>s+b.v,0);
  const bPend=bols.filter(b=>b.s==='PENDENTE').reduce((s,b)=>s+b.v,0);
  const tFix=fix.reduce((s,f)=>s+f.v,0);
  const tFn=fns.reduce((s,f)=>s+f.sal*1.19+(f.vt||0)+(f.vr||0),0);
  const saidas=bPago+tFix+tFn;
  const saldo=tRec-saidas;
  document.getElementById('hero').innerHTML=`
    <div class="hero">
      <div class="hero-label">Saldo · ${MESES[curM]}</div>
      <div class="hero-val ${saldo>=0?'pos':'neg'} num">${brl(saldo)}</div>
      <div class="hero-split">
        <div class="hero-col"><div class="hl"><span class="hdot" style="background:#5BD89A"></span>Entradas</div><div class="hv up num">${brl(tRec)}</div></div>
        <div class="hero-col"><div class="hl"><span class="hdot" style="background:#FF8A80"></span>Saídas</div><div class="hv dn num">${brl(saidas)}</div></div>
      </div>
    </div>
    ${bPend>0?`<div class="chip full" style="border-color:var(--amber);background:var(--amber-soft)"><div class="chip-l"><span class="ic" style="background:#fff;color:var(--amber)"><svg viewBox="0 0 24 24" stroke="currentColor"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></span>Boletos a vencer</div><div class="chip-v a num">${brl(bPend)}</div></div>`:''}`;
  const max=Math.max(...FORMAS.map(f=>parseFloat(rec[f.k])||0),1);
  document.getElementById('d-rec').innerHTML=FORMAS.map(f=>{const v=parseFloat(rec[f.k])||0;const pct=tRec>0?(v/tRec*100).toFixed(0):0;const w=v/max*100;return`<div class="li"><div class="li-dot" style="background:${f.c}"></div><div class="li-b"><div class="li-t">${f.l}</div><div class="prog"><div class="prog-f" style="width:${w}%;background:${f.c}"></div></div></div><div class="li-r"><div class="li-v">${brl(v)}</div><div class="li-m">${pct}%</div></div></div>`;}).join('');
  const r5=bols.slice(-4).reverse();
  document.getElementById('d-bol').innerHTML=r5.length?r5.map(b=>`<div class="li"><div class="li-b"><div class="li-t">${b.d}</div><div class="li-s">${b.cat} · vence ${fd(b.venc)}</div></div><div class="li-r"><div class="li-v">${brl(b.v)}</div>${badge(b.s,`tBol(${bols.indexOf(b)})`)}</div></div>`).join(''):emptyState('Nenhum boleto lançado neste mês');
}

function emptyState(msg){return`<div class="empty-s"><svg viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg><p>${msg}</p></div>`;}

async function rRec(){
  const rec=await getRec(curM);document.getElementById('rec-mes-label').textContent=MESES[curM];
  document.getElementById('r-list').innerHTML=FORMAS.map(f=>`<div class="ri"><div class="li-dot" style="background:${f.c}"></div><div class="ri-label">${f.l}</div><div class="ri-in"><span>R$</span><input id="ri-${f.k}" type="number" inputmode="decimal" placeholder="0,00" value="${rec[f.k]||''}"/></div></div>`).join('');
}
async function saveRec(){if(!guard())return;const d={};FORMAS.forEach(f=>{d[f.k]=parseFloat(document.getElementById('ri-'+f.k)?.value)||0;});await dbSet(mk('rec',curM),d);toast('Entradas salvas');}

async function addBol(){if(!guard())return;const d=document.getElementById('b-desc').value.trim();const venc=document.getElementById('b-venc').value;const v=parseFloat(document.getElementById('b-val').value)||0;const cat=document.getElementById('b-cat').value;const forma=document.getElementById('b-forma').value;if(!d||!v){toast('Preencha descrição e valor','err');return;}const bols=await getBols(curM);bols.push({id:uid(),d,venc,v,cat,forma,s:'PENDENTE'});await dbSet(mk('bol',curM),bols);closeSheet('s-bol');['b-desc','b-venc','b-val'].forEach(i=>document.getElementById(i).value='');toast('Boleto adicionado');await rBol();updateBadge();}
async function tBol(i){if(!guard())return;const bols=await getBols(curM);if(!bols[i])return;bols[i].s=nextSt(bols[i].s);await dbSet(mk('bol',curM),bols);if(bols[i].s==='PAGO')toast(`"${bols[i].d}" marcado como pago`);await rBol();if(curPage()==='resumo')await rResumo();updateBadge();}
async function dBol(i){if(!guard())return;const bols=await getBols(curM);if(!confirm(`Remover "${bols[i]?.d}"?`))return;bols.splice(i,1);await dbSet(mk('bol',curM),bols);toast('Boleto removido','inf');await rBol();updateBadge();}
async function rBol(){
  const bols=await getBols(curM);
  const pg=bols.filter(b=>b.s==='PAGO').reduce((s,b)=>s+b.v,0);
  const pd=bols.filter(b=>b.s==='PENDENTE').reduce((s,b)=>s+b.v,0);
  const vc=bols.filter(b=>b.s==='VENCIDO').reduce((s,b)=>s+b.v,0);
  document.getElementById('b-cards').innerHTML=`
    <div class="chip"><div class="chip-l"><span class="ic" style="background:var(--green-soft);color:var(--green)"><svg viewBox="0 0 24 24" stroke="currentColor"><polyline points="20 6 9 17 4 12"/></svg></span>Pagos</div><div class="chip-v g num">${brl(pg)}</div></div>
    <div class="chip"><div class="chip-l"><span class="ic" style="background:var(--amber-soft);color:var(--amber)"><svg viewBox="0 0 24 24" stroke="currentColor"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></span>Pendentes</div><div class="chip-v a num">${brl(pd)}</div></div>
    <div class="chip full"><div class="chip-l"><span class="ic" style="background:var(--red-soft);color:var(--red)"><svg viewBox="0 0 24 24" stroke="currentColor"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg></span>Vencidos</div><div class="chip-v r num">${brl(vc)}</div></div>`;
  document.getElementById('b-list').innerHTML=bols.length?`<div class="lcard">${bols.map((b,i)=>`<div class="li"><div class="li-b"><div class="li-t">${b.d}</div><div class="li-s">${b.cat} · ${b.forma} · vence ${fd(b.venc)}</div></div><div class="li-r"><div class="li-v">${brl(b.v)}</div>${badge(b.s,`tBol(${i})`)}</div><button class="del-icon" onclick="dBol(${i})"><svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button></div>`).join('')}</div>`:emptyState('Nenhum boleto — toque em + para adicionar');
}

async function addFix(){if(!guard())return;const d=document.getElementById('f-desc').value.trim();const v=parseFloat(document.getElementById('f-val').value)||0;const dia=document.getElementById('f-dia').value||'—';const forma=document.getElementById('f-forma').value;if(!d||!v){toast('Preencha descrição e valor','err');return;}const fix=await getFix();fix.push({id:uid(),d,v,dia,forma});await dbSet(mk('fix'),fix);closeSheet('s-fix');['f-desc','f-val','f-dia'].forEach(i=>document.getElementById(i).value='');toast('Custo fixo adicionado');await rFix();}
async function tFix(i){if(!guard())return;const m=curM,st=await getCfSt(m),fix=await getFix();const id=fix[i]?.id;if(!id)return;st[id]=nextSt(st[id]||'PENDENTE');await dbSet(mk('cfst',m),st);if(st[id]==='PAGO')toast(`"${fix[i].d}" marcado como pago`);await rFix();}
async function dFix(i){if(!guard())return;const fix=await getFix();if(!confirm(`Remover "${fix[i]?.d}"?`))return;fix.splice(i,1);await dbSet(mk('fix'),fix);toast('Custo removido','inf');await rFix();}
async function rFix(){
  const fix=await getFix(),st=await getCfSt(curM);
  const total=fix.reduce((s,f)=>s+f.v,0);const pg=fix.filter(f=>st[f.id]==='PAGO').reduce((s,f)=>s+f.v,0);
  document.getElementById('f-cards').innerHTML=`
    <div class="chip full"><div class="chip-l"><span class="ic" style="background:var(--slate-soft);color:var(--slate)"><svg viewBox="0 0 24 24" stroke="currentColor"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></span>Total mensal</div><div class="chip-v num">${brl(total)}</div></div>
    <div class="chip"><div class="chip-l"><span class="ic" style="background:var(--green-soft);color:var(--green)"><svg viewBox="0 0 24 24" stroke="currentColor"><polyline points="20 6 9 17 4 12"/></svg></span>Pagos</div><div class="chip-v g num">${brl(pg)}</div></div>
    <div class="chip"><div class="chip-l"><span class="ic" style="background:var(--amber-soft);color:var(--amber)"><svg viewBox="0 0 24 24" stroke="currentColor"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></span>Em aberto</div><div class="chip-v a num">${brl(total-pg)}</div></div>`;
  document.getElementById('f-list').innerHTML=fix.length?`<div class="lcard">${fix.map((f,i)=>`<div class="li"><div class="li-b"><div class="li-t">${f.d}</div><div class="li-s">${f.forma} · dia ${f.dia}</div></div><div class="li-r"><div class="li-v">${brl(f.v)}</div>${badge(st[f.id]||'PENDENTE',`tFix(${i})`)}</div><button class="del-icon" onclick="dFix(${i})"><svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button></div>`).join('')}</div>`:emptyState('Nenhum custo fixo — toque em + para adicionar');
}

async function addFn(){if(!guard())return;const nome=document.getElementById('fn-nome').value.trim();const cargo=document.getElementById('fn-cargo').value.trim();const sal=parseFloat(document.getElementById('fn-sal').value)||0;const vt=parseFloat(document.getElementById('fn-vt').value)||0;const vr=parseFloat(document.getElementById('fn-vr').value)||0;if(!nome||!sal){toast('Preencha nome e salário','err');return;}const fns=await getFns();fns.push({id:uid(),nome,cargo,sal,vt,vr});await dbSet(mk('fns'),fns);closeSheet('s-fn');['fn-nome','fn-cargo','fn-sal','fn-vt','fn-vr'].forEach(i=>document.getElementById(i).value='');toast('Funcionário adicionado');await rEq();}
async function tFn(i){if(!guard())return;const m=curM,st=await getFnSt(m),fns=await getFns();const id=fns[i]?.id;if(!id)return;st[id]=nextSt(st[id]||'PENDENTE');await dbSet(mk('fnst',m),st);if(st[id]==='PAGO')toast(`Salário de "${fns[i].nome}" pago`);await rEq();}
async function dFn(i){if(!guard())return;const fns=await getFns();if(!confirm(`Remover "${fns[i]?.nome}"?`))return;fns.splice(i,1);await dbSet(mk('fns'),fns);toast('Funcionário removido','inf');await rEq();}
async function rEq(){
  const fns=await getFns(),st=await getFnSt(curM);
  const tSal=fns.reduce((s,f)=>s+f.sal,0);const tCusto=fns.reduce((s,f)=>s+f.sal*1.19+(f.vt||0)+(f.vr||0),0);
  document.getElementById('e-cards').innerHTML=`
    <div class="chip"><div class="chip-l"><span class="ic" style="background:var(--slate-soft);color:var(--slate)"><svg viewBox="0 0 24 24" stroke="currentColor"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></span>Funcionários</div><div class="chip-v num">${fns.length}</div></div>
    <div class="chip"><div class="chip-l"><span class="ic" style="background:var(--green-soft);color:var(--green)"><svg viewBox="0 0 24 24" stroke="currentColor"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></span>Salários</div><div class="chip-v num">${brl(tSal)}</div></div>
    <div class="chip full" style="border-color:var(--green);background:var(--green-soft)"><div class="chip-l"><span class="ic" style="background:#fff;color:var(--green)"><svg viewBox="0 0 24 24" stroke="currentColor"><path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4"/><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"/><path d="M18 12a2 2 0 0 0-2 2c0 1.1.9 2 2 2h4v-4z"/></svg></span>Custo total com encargos</div><div class="chip-v g num">${brl(tCusto)}</div></div>`;
  const wrap=document.getElementById('e-list');
  if(!fns.length){wrap.innerHTML=emptyState('Nenhum funcionário — toque em + para adicionar');return;}
  wrap.innerHTML=fns.map((f,i)=>{const inss=f.sal*.11,fgts=f.sal*.08,custo=f.sal+inss+fgts+(f.vt||0)+(f.vr||0);const av=f.nome.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();const s=st[f.id]||'PENDENTE';return`<div class="fc"><div class="fc-top"><div class="fc-av">${av}</div><div style="flex:1;min-width:0"><div class="fc-name">${f.nome}</div><div class="fc-cargo">${f.cargo||'—'}</div></div>${badge(s,`tFn(${i})`)}</div><div class="fc-rows"><div>Salário<div class="v">${brl(f.sal)}</div></div><div>INSS 11%<div class="v">${brl(inss)}</div></div><div>FGTS 8%<div class="v">${brl(fgts)}</div></div><div>V. Transporte<div class="v">${brl(f.vt)}</div></div><div>V. Refeição<div class="v">${brl(f.vr)}</div></div><div></div></div><div class="fc-bot"><div><div class="fc-total-l">Custo total</div><div class="fc-total">${brl(custo)}</div></div><button class="del-btn" onclick="dFn(${i})">Remover</button></div></div>`;}).join('');
}

function renderCfg(){
  document.getElementById('cfg-content').innerHTML=`
    <div class="seti"><div><div class="sl">${curUser.name}</div><div class="ss">${curUser.role==='admin'?'Administrador · acesso total':'Visualizador · somente leitura'}</div></div></div>
    ${isAdmin()?`<div class="seti-eyebrow">Alterar senhas</div>${USERS.map(u=>`<div class="seti"><div><div class="sl">${u.name}</div></div><div class="seti-r"><input id="npw-${u.id}" type="password" placeholder="Nova senha"/><button onclick="changePw('${u.id}')">Salvar</button></div></div>`).join('')}`:''}
    <div class="seti-eyebrow">Sessão</div>
    <div class="seti"><div><div class="sl">Sair da conta</div><div class="ss">Voltar para a tela de login</div></div><button class="logout-btn" onclick="logout()">Sair</button></div>`;
}
async function changePw(id){const pw=document.getElementById('npw-'+id)?.value?.trim();if(!pw||pw.length<4){toast('Mínimo 4 caracteres','err');return;}await setPw(id,pw);document.getElementById('npw-'+id).value='';toast('Senha alterada');}
function logout(){curUser=null;closeSheet('s-cfg');document.getElementById('app').classList.remove('on');document.getElementById('login').classList.remove('off');selUid='admin';renderUsers();}

renderUsers();
</script>
</body>
