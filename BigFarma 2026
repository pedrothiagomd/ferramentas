<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>BigFarma · Financeiro</title>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-firestore-compat.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --paper:#F4F6F3;
  --surface:#FFFFFF;
  --ink:#16241D;
  --ink2:#5E6E65;
  --ink3:#94A199;
  --line:#E4E9E4;
  --green:#0E8C5A;
  --green-d:#0A6E47;
  --green-soft:#E5F3EC;
  --amber:#B9740A;
  --amber-soft:#FBF0DC;
  --red:#C2362E;
  --red-soft:#F8E4E2;
  --slate:#3D5564;
  --slate-soft:#E8EEF1;
  --shadow:0 1px 2px rgba(22,36,29,.04),0 4px 16px rgba(22,36,29,.05);
  --shadow-lg:0 8px 32px rgba(22,36,29,.12);
  --disp:'Space Grotesk',sans-serif;
  --body:'Inter',sans-serif;
  --nav-h:66px;--top-h:58px;
}
body{font-family:var(--body);background:var(--paper);color:var(--ink);height:100vh;overflow:hidden;font-size:15px;-webkit-font-smoothing:antialiased}
.num{font-family:var(--disp);font-variant-numeric:tabular-nums;font-feature-settings:"tnum"}

/* ───── LOGIN ───── */
#login{position:fixed;inset:0;background:var(--paper);z-index:999;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:28px}
#login.off{display:none}
.l-mark{width:56px;height:56px;border-radius:16px;background:var(--green);display:flex;align-items:center;justify-content:center;margin-bottom:18px;box-shadow:0 6px 20px rgba(14,140,90,.3)}
.l-mark svg{width:30px;height:30px;stroke:#fff;fill:none;stroke-width:2.5}
#login h1{font-family:var(--disp);font-size:1.5rem;font-weight:700;letter-spacing:-.02em;margin-bottom:3px}
#login .sub{color:var(--ink2);font-size:.85rem;margin-bottom:30px}
.u-list{width:100%;max-width:330px;display:flex;flex-direction:column;gap:8px;margin-bottom:18px}
.u-item{display:flex;align-items:center;gap:12px;padding:12px 13px;background:var(--surface);border:1.5px solid var(--line);border-radius:14px;cursor:pointer;width:100%;transition:border-color .15s,box-shadow .15s}
.u-item.sel{border-color:var(--green);box-shadow:0 0 0 3px var(--green-soft)}
.u-av{width:38px;height:38px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-family:var(--disp);font-weight:700;font-size:.82rem;flex-shrink:0}
.u-info .name{font-size:.9rem;font-weight:600;color:var(--ink);text-align:left}
.u-info .role{font-size:.72rem;color:var(--ink3);text-align:left;margin-top:1px}
.pw-wrap{width:100%;max-width:330px;position:relative;margin-bottom:10px}
.pw-wrap input{width:100%;padding:14px 44px 14px 15px;background:var(--surface);border:1.5px solid var(--line);border-radius:12px;color:var(--ink);font-size:.95rem;font-family:var(--body);outline:none;-webkit-appearance:none;transition:border-color .15s}
.pw-wrap input:focus{border-color:var(--green)}
.pw-wrap input::placeholder{color:var(--ink3)}
.pw-wrap .eye{position:absolute;right:6px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--ink3);font-size:.95rem;cursor:pointer;padding:8px}
#login-err{color:var(--red);font-size:.82rem;min-height:18px;margin-bottom:6px;width:100%;max-width:330px;text-align:center;font-weight:500}
.l-btn{width:100%;max-width:330px;padding:15px;background:var(--green);color:#fff;border:none;border-radius:12px;font-size:.95rem;font-weight:700;font-family:var(--body);cursor:pointer;transition:background .15s}
.l-btn:active{background:var(--green-d)}
.l-foot{margin-top:22px;font-size:.72rem;color:var(--ink3);display:flex;align-items:center;gap:6px}
.l-foot .dot{width:6px;height:6px;border-radius:50%;background:var(--green)}

/* ───── APP SHELL ───── */
#app{display:none;flex-direction:column;height:100vh}
#app.on{display:flex}
.topbar{height:var(--top-h);background:var(--surface);border-bottom:1px solid var(--line);display:flex;align-items:center;justify-content:space-between;padding:0 16px;flex-shrink:0}
.tb-l{display:flex;align-items:center;gap:9px}
.tb-mark{width:30px;height:30px;border-radius:9px;background:var(--green);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.tb-mark svg{width:17px;height:17px;stroke:#fff;fill:none;stroke-width:2.5}
.tb-title{font-family:var(--disp);font-size:1.02rem;font-weight:600;letter-spacing:-.01em}
.tb-r{display:flex;align-items:center;gap:8px}
.mpill{display:flex;align-items:center;gap:6px;background:var(--paper);border:1px solid var(--line);border-radius:99px;padding:6px 12px;font-size:.78rem;font-weight:600;color:var(--slate);cursor:pointer}
.mpill svg{width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2}
.cfg{width:34px;height:34px;border-radius:10px;background:var(--paper);border:1px solid var(--line);color:var(--ink2);cursor:pointer;display:flex;align-items:center;justify-content:center}
.cfg svg{width:17px;height:17px;stroke:currentColor;fill:none;stroke-width:1.8}
.ro-bar{background:var(--amber-soft);padding:7px;font-size:.74rem;color:var(--amber);text-align:center;font-weight:600;flex-shrink:0;display:none;align-items:center;justify-content:center;gap:6px}
.ro-bar svg{width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2}

.scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:16px 16px 96px}

/* ───── BOTTOM NAV ───── */
.bnav{height:var(--nav-h);background:var(--surface);border-top:1px solid var(--line);display:flex;flex-shrink:0;padding-bottom:env(safe-area-inset-bottom)}
.nb{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;background:none;border:none;color:var(--ink3);cursor:pointer;font-size:.6rem;font-weight:600;font-family:var(--body);position:relative;transition:color .15s}
.nb.on{color:var(--green)}
.nb svg{width:21px;height:21px;fill:none;stroke:currentColor;stroke-width:1.9;stroke-linecap:round;stroke-linejoin:round}
.nb.on svg{stroke-width:2.2}
.nbadge{position:absolute;top:7px;right:calc(50% - 19px);background:var(--red);color:#fff;font-size:.54rem;font-weight:700;min-width:15px;height:15px;display:flex;align-items:center;justify-content:center;padding:0 4px;border-radius:99px}
.nbadge.off{display:none}

/* ───── PAGES ───── */
.page{display:none;animation:fade .25s ease}
.page.on{display:block}
@keyframes fade{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
.eyebrow{font-size:.68rem;font-weight:700;color:var(--ink3);text-transform:uppercase;letter-spacing:.1em;margin:22px 2px 10px}
.eyebrow:first-child{margin-top:2px}

/* ───── HERO BALANCE (signature) ───── */
.hero{background:var(--ink);border-radius:20px;padding:20px;color:#fff;margin-bottom:14px;position:relative;overflow:hidden;box-shadow:var(--shadow-lg)}
.hero::after{content:"";position:absolute;top:-40px;right:-40px;width:140px;height:140px;border-radius:50%;background:radial-gradient(circle,rgba(14,140,90,.35),transparent 70%)}
.hero-label{font-size:.72rem;color:rgba(255,255,255,.6);font-weight:600;text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px;position:relative}
.hero-val{font-family:var(--disp);font-size:2.3rem;font-weight:600;letter-spacing:-.02em;line-height:1;position:relative}
.hero-val.pos{color:#5BD89A}.hero-val.neg{color:#FF8A80}
.hero-split{display:flex;gap:0;margin-top:18px;position:relative}
.hero-col{flex:1}
.hero-col+.hero-col{border-left:1px solid rgba(255,255,255,.12);padding-left:16px}
.hero-col .hl{font-size:.68rem;color:rgba(255,255,255,.55);font-weight:600;display:flex;align-items:center;gap:5px;margin-bottom:4px}
.hero-col .hv{font-family:var(--disp);font-size:1.05rem;font-weight:600}
.hero-col .hv.up{color:#5BD89A}.hero-col .hv.dn{color:#FF8A80}
.hdot{width:6px;height:6px;border-radius:50%}

/* ───── STAT CHIPS ───── */
.chips{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:4px}
.chip{background:var(--surface);border:1px solid var(--line);border-radius:16px;padding:14px;box-shadow:var(--shadow)}
.chip.full{grid-column:1/-1}
.chip-l{font-size:.71rem;color:var(--ink2);font-weight:600;margin-bottom:6px;display:flex;align-items:center;gap:6px}
.chip-l .ic{width:18px;height:18px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.chip-l .ic svg{width:11px;height:11px;stroke-width:2.2;fill:none}
.chip-v{font-family:var(--disp);font-size:1.25rem;font-weight:600;letter-spacing:-.01em}
.chip-v.g{color:var(--green)}.chip-v.a{color:var(--amber)}.chip-v.r{color:var(--red)}

/* ───── LIST ───── */
.lcard{background:var(--surface);border:1px solid var(--line);border-radius:16px;overflow:hidden;box-shadow:var(--shadow)}
.li{display:flex;align-items:center;gap:12px;padding:13px 14px;border-bottom:1px solid var(--line)}
.li:last-child{border-bottom:none}
.li-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.li-b{flex:1;min-width:0}
.li-t{font-size:.88rem;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.li-s{font-size:.73rem;color:var(--ink3);margin-top:2px}
.li-r{text-align:right;flex-shrink:0;display:flex;flex-direction:column;align-items:flex-end;gap:5px}
.li-v{font-family:var(--disp);font-size:.95rem;font-weight:600}
.li-m{font-size:.7rem;color:var(--ink3)}
.prog{height:4px;background:var(--line);border-radius:99px;margin-top:6px;overflow:hidden}
.prog-f{height:100%;border-radius:99px;transition:width .5s cubic-bezier(.4,0,.2,1)}

/* ───── BADGE ───── */
.badge{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:99px;font-size:.68rem;font-weight:700;cursor:pointer;user-select:none;transition:transform .1s}
.badge:active{transform:scale(.95)}
.badge::before{content:"";width:5px;height:5px;border-radius:50%;background:currentColor}
.badge.pendente{background:var(--amber-soft);color:var(--amber)}
.badge.pago{background:var(--green-soft);color:var(--green-d)}
.badge.vencido{background:var(--red-soft);color:var(--red)}
.badge.cancelado{background:var(--paper);color:var(--ink3)}

/* ───── RECEBIMENTOS ───── */
.ri{display:flex;align-items:center;gap:12px;padding:14px;border-bottom:1px solid var(--line)}
.ri:last-child{border-bottom:none}
.ri-label{flex:1;font-size:.88rem;font-weight:600}
.ri-in{display:flex;align-items:center;gap:5px;background:var(--paper);border:1.5px solid var(--line);border-radius:10px;padding:8px 11px;transition:border-color .15s}
.ri-in:focus-within{border-color:var(--green);background:var(--surface)}
.ri-in span{font-size:.76rem;color:var(--ink3);font-weight:600}
.ri-in input{width:92px;background:none;border:none;color:var(--ink);font-family:var(--disp);font-size:.92rem;font-weight:600;outline:none;text-align:right;-webkit-appearance:none}
.save-btn{width:100%;padding:15px;background:var(--green);color:#fff;border:none;border-radius:14px;font-size:.92rem;font-weight:700;font-family:var(--body);cursor:pointer;margin-top:14px;box-shadow:0 4px 14px rgba(14,140,90,.25);transition:background .15s}
.save-btn:active{background:var(--green-d)}

/* ───── FAB ───── */
.fab{position:fixed;bottom:80px;right:16px;width:54px;height:54px;border-radius:17px;background:var(--green);color:#fff;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 6px 20px rgba(14,140,90,.4);z-index:50;transition:transform .12s}
.fab svg{width:24px;height:24px;stroke:#fff;fill:none;stroke-width:2.4}
.fab:active{transform:scale(.92)}
.fab.off{display:none}

/* ───── FUNC CARD ───── */
.fc{background:var(--surface);border:1px solid var(--line);border-radius:16px;padding:15px;margin-bottom:10px;box-shadow:var(--shadow)}
.fc-top{display:flex;align-items:center;gap:11px;margin-bottom:13px}
.fc-av{width:42px;height:42px;border-radius:13px;background:var(--slate-soft);color:var(--slate);display:flex;align-items:center;justify-content:center;font-family:var(--disp);font-weight:700;font-size:.92rem;flex-shrink:0}
.fc-name{font-weight:700;font-size:.92rem}
.fc-cargo{font-size:.73rem;color:var(--ink3);margin-top:1px}
.fc-rows{display:grid;grid-template-columns:repeat(3,1fr);gap:10px 8px;font-size:.7rem;color:var(--ink3)}
.fc-rows .v{font-family:var(--disp);font-weight:600;color:var(--ink);font-size:.82rem;margin-top:2px}
.fc-bot{margin-top:13px;padding-top:13px;border-top:1px solid var(--line);display:flex;align-items:center;justify-content:space-between}
.fc-total-l{font-size:.68rem;color:var(--ink3);font-weight:600;text-transform:uppercase;letter-spacing:.05em}
.fc-total{font-family:var(--disp);font-size:1.1rem;font-weight:600;color:var(--green-d);margin-top:1px}
.del-btn{background:none;border:1px solid var(--line);color:var(--ink2);border-radius:9px;padding:7px 13px;font-size:.76rem;font-weight:600;font-family:var(--body);cursor:pointer}
.del-btn:active{background:var(--red-soft);color:var(--red);border-color:var(--red)}
.del-icon{background:none;border:none;color:var(--ink3);cursor:pointer;padding:5px;display:flex}
.del-icon svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.8}
.del-icon:active{color:var(--red)}

.empty-s{text-align:center;padding:38px 20px;color:var(--ink3)}
.empty-s svg{width:34px;height:34px;stroke:var(--ink3);fill:none;stroke-width:1.5;margin-bottom:10px;opacity:.6}
.empty-s p{font-size:.85rem}

/* ───── SHEET ───── */
.sov{position:fixed;inset:0;background:rgba(22,36,29,.4);backdrop-filter:blur(2px);z-index:200;display:none;align-items:flex-end}
.sov.on{display:flex}
.sheet{background:var(--surface);border-radius:24px 24px 0 0;padding:8px 18px 38px;width:100%;max-height:92vh;overflow-y:auto;animation:up .25s cubic-bezier(.2,.8,.2,1)}
@keyframes up{from{transform:translateY(100%)}to{transform:translateY(0)}}
.sh{width:38px;height:4px;background:var(--line);border-radius:99px;margin:8px auto 18px}
.stitle{font-family:var(--disp);font-size:1.1rem;font-weight:600;margin-bottom:18px}
.fg{margin-bottom:13px}
.fg label{display:block;font-size:.68rem;font-weight:700;color:var(--ink2);text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px}
.fg input,.fg select{width:100%;background:var(--paper);border:1.5px solid var(--line);border-radius:11px;padding:12px 13px;color:var(--ink);font-size:.9rem;font-family:var(--body);outline:none;-webkit-appearance:none;appearance:none;transition:border-color .15s}
.fg input:focus,.fg select:focus{border-color:var(--green);background:var(--surface)}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:11px}
.sactions{display:flex;gap:11px;margin-top:8px}
.sactions button{flex:1;padding:14px;border-radius:12px;border:none;font-size:.9rem;font-weight:700;font-family:var(--body);cursor:pointer}
.s-cancel{background:var(--paper);color:var(--ink2);border:1px solid var(--line)!important}
.s-ok{background:var(--green);color:#fff}
.s-ok:active{background:var(--green-d)}

/* ───── MONTH DRAWER ───── */
.mov{position:fixed;inset:0;background:rgba(22,36,29,.4);backdrop-filter:blur(2px);z-index:300;display:none;align-items:flex-end}
.mov.on{display:flex}
.mdrawer{background:var(--surface);border-radius:24px 24px 0 0;padding:8px 18px 38px;width:100%;animation:up .25s cubic-bezier(.2,.8,.2,1)}
.mdrawer .lbl{font-family:var(--disp);font-size:.95rem;font-weight:600;text-align:center;margin-bottom:4px}
.mgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:14px}
.mbtn{background:var(--paper);border:1.5px solid var(--line);border-radius:11px;padding:12px 4px;text-align:center;font-size:.84rem;font-weight:600;font-family:var(--body);color:var(--ink2);cursor:pointer;transition:all .12s}
.mbtn.on{background:var(--green);border-color:var(--green);color:#fff}

/* ───── SETTINGS ───── */
.seti{display:flex;align-items:center;justify-content:space-between;padding:14px 0;border-bottom:1px solid var(--line)}
.seti:last-child{border-bottom:none}
.seti .sl{font-size:.88rem;font-weight:600}
.seti .ss{font-size:.72rem;color:var(--ink3);margin-top:2px}
.seti-r{display:flex;gap:7px;align-items:center}
.seti-r input{width:118px;background:var(--paper);border:1.5px solid var(--line);border-radius:9px;padding:8px 11px;color:var(--ink);font-size:.82rem;font-family:var(--body);outline:none;-webkit-appearance:none}
.seti-r input:focus{border-color:var(--green)}
.seti-r button{background:var(--green);color:#fff;border:none;border-radius:9px;padding:8px 13px;font-size:.8rem;font-weight:600;font-family:var(--body);cursor:pointer}
.seti-eyebrow{font-size:.66rem;font-weight:700;color:var(--ink3);text-transform:uppercase;letter-spacing:.1em;margin:18px 0 4px}
.logout-btn{background:none;color:var(--red);border:1px solid var(--red-soft);border-radius:10px;padding:8px 15px;font-size:.82rem;font-weight:600;font-family:var(--body);cursor:pointer}
.logout-btn:active{background:var(--red-soft)}

/* ───── TOAST ───── */
.tw{position:fixed;top:64px;left:16px;right:16px;z-index:999;pointer-events:none;display:flex;flex-direction:column;align-items:center}
.toast{background:var(--ink);color:#fff;border-radius:12px;padding:11px 16px;font-size:.84rem;font-weight:500;display:flex;align-items:center;gap:8px;margin-bottom:6px;box-shadow:var(--shadow-lg);animation:tin .25s cubic-bezier(.2,.8,.2,1);max-width:340px}
@keyframes tin{from{opacity:0;transform:translateY(-10px) scale(.96)}to{opacity:1;transform:translateY(0) scale(1)}}
.toast .td{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.toast.ok .td{background:#5BD89A}
.toast.err .td{background:#FF8A80}
.toast.inf .td{background:#7CB8E8}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login">
  <div class="l-mark"><svg viewBox="0 0 24 24"><path d="M12 2v20M2 12h20"/></svg></div>
  <h1>BigFarma</h1>
  <div class="sub">Controle Financeiro · 2026</div>
  <div class="u-list" id="user-btns"></div>
  <div class="pw-wrap">
    <input id="pw-inp" type="password" placeholder="Senha" onkeydown="if(event.key==='Enter')doLogin()"/>
    <button class="eye" onclick="togglePw()">Ver</button>
  </div>
  <div id="login-err"></div>
  <button class="l-btn" onclick="doLogin()">Entrar</button>
  <div class="l-foot"><span class="dot"></span>Sincronizado na nuvem</div>
</div>

<!-- APP -->
<div id="app">
  <div class="topbar">
    <div class="tb-l">
      <div class="tb-mark"><svg viewBox="0 0 24 24"><path d="M12 2v20M2 12h20"/></svg></div>
      <div class="tb-title" id="ttitle">Resumo</div>
    </div>
    <div class="tb-r">
      <div class="mpill" onclick="openMov()"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg><span id="mlabel">Março</span></div>
      <button class="cfg" onclick="openSheet('s-cfg')"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></button>
    </div>
  </div>
